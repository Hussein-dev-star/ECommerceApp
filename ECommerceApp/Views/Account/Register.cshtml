@model ECommerceApp.Models.RegisterViewModel
@{
    ViewData["Title"] = "إنشاء حساب جديد";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    <h2 class="text-center fw-bold text-success mb-4">إنشاء حساب جديد</h2>
                    <form asp-action="Register" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Email" class="form-control rounded-3" placeholder="Email" />
                            <label asp-for="Email">البريد الإلكتروني</label>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="form-floating mb-3">
                            <input asp-for="Password" class="form-control rounded-3" placeholder="Password" />
                            <label asp-for="Password">كلمة المرور</label>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="form-floating mb-3">
                            <input asp-for="ConfirmPassword" class="form-control rounded-3" placeholder="Confirm" />
                            <label asp-for="ConfirmPassword">تأكيد كلمة المرور</label>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-success btn-lg w-100 rounded-pill shadow-sm">تسجيل الحساب 🚀</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>