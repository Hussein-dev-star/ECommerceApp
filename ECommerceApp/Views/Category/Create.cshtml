@model ECommerceApp.Models.Category
@{
    ViewData["Title"] = "إضافة قسم جديد";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-success text-white fw-bold"><h3>إضافة قسم جديد</h3></div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">اسم القسم</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">الوصف</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">إلغاء</a>
                            <button type="submit" class="btn btn-success px-4">حفظ 💾</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>