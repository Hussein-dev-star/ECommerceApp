@model ECommerceApp.Models.Category
@{
    ViewData["Title"] = "تعديل القسم";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark fw-bold"><h3>تعديل القسم: @Model.Name</h3></div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">اسم القسم</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">الوصف</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">إلغاء</a>
                            <button type="submit" class="btn btn-warning fw-bold px-4">تحديث 🔄</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>