@model IEnumerable<ECommerceApp.Models.Category>
@{
    ViewData["Title"] = "إدارة الأقسام 🛠️";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold m-0">📂 إدارة أقسام المتجر</h2>
        <a asp-action="Create" class="btn btn-success rounded-pill px-4">➕ إضافة قسم جديد</a>
    </div>

    <table class="table table-hover align-middle bg-white shadow-sm rounded border">
        <thead class="table-dark">
            <tr>
                <th>اسم القسم</th>
                <th>الوصف</th>
                <th class="text-center">التحكم</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cat in Model)
            {
                <tr>
                    <td class="fw-bold text-primary">@cat.Name</td>
                    <td class="text-muted">@cat.Description</td>
                    <td class="text-center">
                        <div class="btn-group gap-1">
                            <a asp-action="Edit" asp-route-id="@cat.Id" class="btn btn-outline-warning btn-sm rounded-pill px-3">تعديل</a>
                            <form asp-action="Delete" asp-route-id="@cat.Id" method="post" onsubmit="return confirm('هل أنت متأكد؟ حذف القسم سيحذف كل منتجاته!');" class="d-inline">
                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">حذف</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>