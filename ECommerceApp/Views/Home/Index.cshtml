@model IEnumerable<ECommerceApp.Models.Product>

@{
    ViewData["Title"] = "الصفحة الرئيسية - متجر إلكتروني";
}

<!-- البنر الرئيسي (Hero Section) -->
<div class="bg-dark text-white py-5 mb-5 rounded-4 shadow" style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6));">
    <div class="container py-5 text-center">
        <h1 class="display-3 fw-bold mb-3 text-warning">أهلاً بك في ECommerceApp 🛒</h1>
        <p class="lead fs-4 mb-4 text-light">وجهتك الأولى لأحدث الأجهزة الإلكترونية والأزياء العصرية بأفضل الأسعار</p>
        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
            <a href="/Product" class="btn btn-primary btn-lg px-5 rounded-pill shadow fw-bold">تسوق الآن 🛍️</a>
        </div>
    </div>
</div>

<!-- قسم المنتجات المميزة / الأعلى مبيعاً -->
<div class="container my-5">
    <h2 class="text-center fw-bold text-dark mb-4">🔥 المنتجات الأكثر مبيعاً المقترحة لك</h2>
    <div class="row">
        @if (Model == null || !Model.Any())
        {
            <p class="text-muted text-center">قم بالدخول كأدمن وإضافة منتجات لتظهر هنا.</p>
        }
        else
        {
            @foreach (var product in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-0 rounded-3">
                        <img src="@product.ImageUrl" class="card-img-top p-3 rounded-4" alt="@product.Name" style="height: 200px; object-fit: contain;">
                        <div class="card-body d-flex flex-column">
                            <span class="badge bg-secondary align-self-start mb-2">@product.Category?.Name</span>
                            <h5 class="card-title fw-bold text-dark">@product.Name</h5>
                            <span class="h5 fw-bold text-success mt-auto">@product.Price.ToString("C")</span>
                            <a href="/Product/Details/@product.Id" class="btn btn-sm btn-outline-primary mt-3 rounded-pill">عرض المنتج</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>