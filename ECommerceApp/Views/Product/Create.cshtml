@model ECommerceApp.Models.Product

@{
    ViewData["Title"] = "إضافة منتج جديد";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">إضافة منتج جديد للمتجر</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        <!-- رسالة الأخطاء العامة إن وجدت -->
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold">اسم المنتج</label>
                            <input asp-for="Name" class="form-line form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Price" class="form-label fw-bold">السعر</label>
                                <input asp-for="Price" class="form-control" type="number" step="0.01" />
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="StockQuantity" class="form-label fw-bold">الكمية في المخزن</label>
                                <input asp-for="StockQuantity" class="form-control" type="number" />
                                <span asp-validation-for="StockQuantity" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CategoryId" class="form-label fw-bold">قسم المنتج</label>
                            <select asp-for="CategoryId" class="form-select"
                                    asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))">
                                <option value="">-- اختر القسم --</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold">وصف المنتج</label>
                            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">العودة للمتجر</a>
                            <button type="submit" class="btn btn-success px-5">حفظ المنتج 💾</button>
                        </div>
                        <!-- حقل رفع الملف الجديد -->
    <div class="mb-3">
        <label class="form-label fw-bold">صورة المنتج الحقيقية</label>
        <input type="file" name="imageFile" class="form-control" accept="image/*" />
    </div>

    <button type="submit" class="btn btn-success">حفظ المنتج 💾</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- السطور دي عشان تخلي الـ Validation يشتغل فوراً عند العميل بدون ما يعمل ريفريش للصفحة -->
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}