@model ECommerceApp.Models.Product

@{
    ViewData["Title"] = "تفاصيل المنتج - " + Model.Name;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="row g-0">
                    <!-- جانب الصورة -->
                    <div class="col-md-5 bg-light d-flex align-items-center justify-content-center p-4">
                        <img src="@Model.ImageUrl" class="img-fluid rounded-3" alt="@Model.Name" style="max-height: 400px; object-fit: contain;">
                    </div>

                    <!-- جانب البيانات -->
                    <div class="col-md-7">
                        <div class="card-body p-5">
                            <span class="badge bg-primary px-3 py-2 rounded-pill mb-3">@Model.Category?.Name</span>
                            <h1 class="display-5 fw-bold text-dark mb-3">@Model.Name</h1>

                            <div class="mb-4">
                                <span class="text-muted fs-5">السعر الحالي:</span>
                                <span class="h2 fw-bold text-success d-block">@Model.Price.ToString("C")</span>
                            </div>

                            <hr class="my-4 opacity-25">

                            <h5 class="fw-bold text-secondary">وصف المنتج:</h5>
                            <p class="text-muted fs-5 lh-base">@Model.Description</p>

                            <div class="mt-4 mb-5">
                                <h6 class="fw-bold">حالة المخزن:</h6>
                                @if (Model.StockQuantity > 0)
                                {
                                    <span class="badge bg-success-subtle text-success border border-success px-3 py-2">
                                        متوفر - المتبقي (@Model.StockQuantity) قطعة
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger border border-danger px-3 py-2">
                                        نفذت الكمية من المخزن ❌
                                    </span>
                                }
                            </div>

                            <div class="d-flex gap-3">
                                <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 rounded-pill">
                                    ⬅ العودة للمتجر
                                </a>
                                <a href="/Cart/AddToCart/@Model.Id" class="btn btn-primary btn-lg px-5 rounded-pill shadow-sm">🛒 إضافة إلى السلة</a>
                                  
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
