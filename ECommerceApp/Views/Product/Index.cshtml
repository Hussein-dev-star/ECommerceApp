@model IEnumerable<ECommerceApp.Models.Product>

@{
    ViewData["Title"] = "متجرنا الإلكتروني - قائمة المنتجات";
}

<div class="container mt-5">
    <div class="row mb-5 align-items-center">
        <!-- فورم البحث عن كلمة -->
        <div class="col-md-6 mb-3 mb-md-0">
            <form asp-action="Index" method="get" class="d-flex gap-2">
                <input type="text" name="searchString" class="form-control rounded-pill px-4" placeholder="ابحث عن منتج معين..." />
                <button type="submit" class="btn btn-primary rounded-pill px-4">بحث 🔍</button>
            </form>
        </div>
        <!-- أزرار الأقسام (Categories) -->
        <div class="col-md-6 text-md-end">
            <span class="fw-bold me-2">الأقسام:</span>
            <a href="/Product" class="btn btn-sm btn-outline-dark rounded-pill px-3 m-1">الكل</a>
            @foreach (var cat in ViewBag.Categories)
            {
                <a href="/Product?categoryId=@cat.Id" class="btn btn-sm btn-outline-secondary rounded-pill px-3 m-1">@cat.Name</a>
            }
        </div>
    </div>
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show text-center fw-bold shadow-sm" role="alert">
            🎉 @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <div class="row mb-4">
        <div class="col-md-12 text-center">
            <h1 class="display-4 fw-bold text-primary">أحدث المنتجات في المتجر</h1>
            <p class="lead text-muted">اكتشف أفضل العروض الحصرية لدينا اليوم</p>
        </div>
    </div>

    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12 text-center">
                <div class="alert alert-warning py-4" role="alert">
                    عذراً، لا توجد منتجات متوفرة في المتجر حالياً!
                </div>
            </div>
        }
        else
        {

@foreach (var product in Model)
{
    <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm border-0 rounded-3">
            <!-- صورة المنتج -->
            <img src="@product.ImageUrl" class="card-img-top p-3 rounded-4" alt="@product.Name" style="height: 250px; object-fit: contain;">
            
            <div class="card-body d-flex flex-column">
                <!-- اسم القسم -->
                <span class="badge bg-secondary align-self-start mb-2">@product.Category?.Name</span>
                
                <!-- اسم المنتج -->
                <h5 class="card-title fw-bold text-dark">@product.Name</h5>
                
                <!-- وصف المنتج -->
                <p class="card-text text-muted flex-grow-1">
                    @(product.Description.Length > 80 ? product.Description.Substring(0, 80) + "..." : product.Description)
                </p>
                
                <hr class="text-muted opacity-25">
                
                <div class="d-flex justify-content-between align-items-center mt-auto">
                    <!-- السعر -->
                    <span class="h5 fw-bold text-success mb-0">@product.Price.ToString("C")</span>
                    
                    <div class="btn-group gap-1">
                        <a href="/Product/Details/@product.Id" class="btn btn-outline-primary btn-sm rounded-pill px-2">التفاصيل</a>
                        
                        @if (User.IsInRole("Admin"))
            {
                    <a href="/Product/Edit/@product.Id" class="btn btn-outline-warning btn-sm rounded-pill px-2">تعديل</a>
                    <form asp-action="Delete" asp-route-id="@product.Id" method="post" onsubmit="return confirm('هل أنت متأكد؟');" class="d-inline">
                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-2">حذف</button>
                    </form>
            }
                                     </div>
                                </div>
                
                            </div>
                        </div>
                   </div>
            }
        }
    </div>
</div>